{
  "id": "/",
  "name": "Restify Music",
  "short_name": "Restify",
  "description": "Modern offline-first music streaming experience with immersive playback, albums, artist forums, and premium aesthetics.",
  "start_url": "/index.html",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "standalone"
  ],
  "orientation": "portrait",
  "background_color": "#0a0a0b",
  "theme_color": "#0a0a0b",
  "lang": "en",
  "dir": "ltr",

  "categories": [
    "music",
    "audio",
    "entertainment"
  ],

  "launch_handler": {
    "client_mode": "focus-existing"
  },

  "prefer_related_applications": false,

  "icons": [
    {
      "src": "src/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    },
    {
      "src": "src/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "src/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],

  "screenshots": [
    {
      "src": "screenshots/home.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Home Screen"
    },
    {
      "src": "screenshots/player.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Music Player"
    },
    {
      "src": "screenshots/desktop-home.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Desktop Experience"
    }
  ],

  "shortcuts": [
    {
      "name": "Home",
      "short_name": "Home",
      "description": "Open music library",
      "url": "/index.html"
    },
    {
      "name": "Albums",
      "short_name": "Albums",
      "description": "Browse albums",
      "url": "/pages/albums.html"
    },
    {
      "name": "Announcements",
      "short_name": "News",
      "description": "Latest announcements",
      "url": "/pages/announces.html"
    },
    {
      "name": "Artist Forums",
      "short_name": "Forums",
      "description": "Join artist discussions",
      "url": "/pages/artistforums.html"
    }
  ],

  "file_handlers": [],

  "edge_side_panel": {
    "preferred_width": 400
  }
}